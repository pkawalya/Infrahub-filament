# ─── Performance: Switch to Redis in production ───────────
# After installing Redis: sudo apt install redis-server
# Then update these values:
#
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
#
# Also ensure the phpredis extension is installed:
#   sudo apt install php-redis && sudo systemctl restart php*-fpm
#
# Current settings (database-backed, suitable for development):
# CACHE_STORE=database
# SESSION_DRIVER=database
# QUEUE_CONNECTION=database
